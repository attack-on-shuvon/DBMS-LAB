create database unidb;
-- create database if not exists unidb;
use unidb;
show databases;

create table student(
student_id int primary key not null,
first_name varchar(15) not null,
last_name varchar(15) not null,
dob date,
email varchar(20)
);
-- drop table student;

create table courses(
course_id int primary key not null,
course_name varchar(20),
credit int check(credit>0)
);
-- drop table courses;

create table enrollment(
student_id int, -- student table teke ansi student id ta;   
course_id int, -- course table teke ansi course id ta;
en_id int,
grade varchar(30),

primary key(en_id),

foreign key(student_id) references student(student_id)
on update cascade
on delete cascade,

foreign key(course_id) references courses(course_id)
on update cascade
on delete cascade  -- or likte paro on delete set null;
);
-- drop table enrollment;

create table attendance(
student_id int,
course_id int,
date DATE ,

primary key (student_id,course_id,date)  -- karon ekta table e ektai primary key takte pare;
										-- ekane  student_id + course_id + date unique hobe 3ta eksate;
);
-- drop table attendance;

create table teacher(
teacher_id int primary key,
name varchar(10),
dept varchar(50) default "CSE"
);

-- drop table teacher;

